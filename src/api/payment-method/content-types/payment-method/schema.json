{
  "kind": "collectionType",
  "collectionName": "payment_methods",
  "info": {
    "singularName": "payment-method",
    "pluralName": "payment-methods",
    "displayName": "Payment Method",
    "description": "Payment methods available for orders (Przelewy24, PayU, Cash on Delivery, etc.)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "provider": {
      "type": "enumeration",
      "enum": [
        "przelewy24",
        "payu",
        "cash_on_delivery",
        "bank_transfer"
      ],
      "required": true
    },
    "fee": {
      "type": "decimal",
      "default": 0
    },
    "feeType": {
      "type": "enumeration",
      "enum": [
        "fixed",
        "percentage"
      ],
      "default": "fixed"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "apiKey": {
      "type": "string",
      "private": true
    },
    "merchantId": {
      "type": "string",
      "private": true
    },
    "supportInstallments": {
      "type": "boolean",
      "default": false
    },
    "minOrderAmount": {
      "type": "decimal"
    },
    "maxOrderAmount": {
      "type": "decimal"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
